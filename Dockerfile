# ============================================
# الـ Base Image
# بناخد Python نسخة خفيفة (slim = أصغر حجم)
# ============================================
FROM python:3.10-slim

# ============================================
# الـ Working Directory
# يعني كل الكود هيتحط في /app جوه الـ container
# ============================================
WORKDIR /app

# ============================================
# نسخ الـ requirements الأول (قبل الكود)
# ليه؟ عشان Docker يعمل cache للـ libraries
# ومتنزلهاش كل مرة لو الكود اتغير بس
# ============================================
COPY requirements.txt .

# ============================================
# تنصيب الـ libraries
# --no-cache-dir = متحفظش cache عشان يقلل الحجم
# ============================================
RUN pip install --no-cache-dir -r requirements.txt

# ============================================
# نسخ باقي الكود كله
# ============================================
COPY . .

# ============================================
# الـ Port اللي التطبيق بيشتغل عليه
# (للتوضيح بس، مش بيفتحه فعلاً)
# ============================================
EXPOSE 7860

# ============================================
# الأمر اللي بيشغل التطبيق لما الـ container يبدأ
# 0.0.0.0 = اقبل connections من أي مكان
# ============================================
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "7860"]
